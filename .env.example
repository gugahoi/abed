# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=
# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=
# Channel ID where users make movie requests
SLACK_REQUEST_CHANNEL_ID=
# Channel ID where approval messages are posted (can be same as request channel)
SLACK_APPROVAL_CHANNEL_ID=
# Radarr instance URL (e.g. http://192.168.1.100:7878)
RADARR_URL=
# Radarr API key from Settings > General
RADARR_API_KEY=
# Comma-separated Slack user IDs who can approve requests (e.g. U123ABC,U456DEF)
APPROVER_SLACK_IDS=
# Radarr quality profile ID (get from /api/v3/qualityProfile)
RADARR_QUALITY_PROFILE_ID=
# Radarr root folder path (get from /api/v3/rootFolder)
RADARR_ROOT_FOLDER_PATH=

# Sonarr (OPTIONAL — omit all four to disable TV show requests)
# Sonarr instance URL (e.g. http://192.168.1.100:8989)
SONARR_URL=
# Sonarr API key from Settings > General
SONARR_API_KEY=
# Sonarr quality profile ID (get from /api/v3/qualityprofile)
SONARR_QUALITY_PROFILE_ID=
# Sonarr root folder path (get from /api/v3/rootfolder)
SONARR_ROOT_FOLDER_PATH=
